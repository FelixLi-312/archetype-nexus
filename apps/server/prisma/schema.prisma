generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User { 
   id        Int      @id @default(autoincrement()) 
   username  String   @unique 
   password  String 
   email     String?  @unique
   nickname  String?
   avatar    String?
   createdAt DateTime @default(now()) 
   updatedAt DateTime @updatedAt
 }

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
